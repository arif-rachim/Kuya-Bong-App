# manggaleh backend integration (see docs/manggaleh-integration-plan.md).
# Copy to ".env" and fill in. Leave VITE_USE_MANGGALEH=false to keep the local
# mock store (the app runs fully offline by default).

VITE_USE_MANGGALEH=false
VITE_MANGGALEH_BASE_URL=https://api.manggaleh.com
VITE_MANGGALEH_TENANT=
VITE_MANGGALEH_ENV=dev
VITE_MANGGALEH_API_KEY=
# Require email-OTP verification at registration. Leave false until email
# delivery is configured in manggaleh (Resend provider, or DEV_OTP_CODE for dev) —
# otherwise send-verification-otp returns 500 and registration would stall.
VITE_MANGGALEH_OTP=false
