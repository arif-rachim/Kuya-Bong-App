# E2E configuration. Copy to ".env.e2e" and `set -a; source .env.e2e; set +a`
# before running `npm run test:e2e` to exercise the suite against a LIVE manggaleh
# tenant. With none of these set, the app builds in mock mode and only the
# backend-agnostic smoke specs run (the manggaleh specs skip).

# --- backend selection (baked into the build) ---
# Point at a dev/staging tenant — NEVER prod (the booking spec creates rows).
VITE_USE_MANGGALEH=true
VITE_MANGGALEH_BASE_URL=https://api.manggaleh.com
VITE_MANGGALEH_TENANT=realief-expert
VITE_MANGGALEH_ENV=dev
VITE_MANGGALEH_API_KEY=mgpk_your_publishable_key
# Leave false unless email OTP delivery is configured in the tenant.
VITE_MANGGALEH_OTP=false

# --- test accounts (must already exist in the tenant; see scripts/manggaleh/seed_users.mjs) ---
E2E_PATIENT_EMAIL=maria@example.com
E2E_PATIENT_PASSWORD=patient123
# Optional second patient for cross-user checks.
E2E_PATIENT2_EMAIL=ahmed@example.com
E2E_PATIENT2_PASSWORD=patient123
# Admin (master admin unlocks sub-admins/audit + all catalogue capabilities).
E2E_ADMIN_EMAIL=admin@reliefexpert.app
E2E_ADMIN_PASSWORD=admin123
# Physiotherapist (enables the physio spec + cross-role guard tests).
E2E_PHYSIO_EMAIL=physio@reliefexpert.app
E2E_PHYSIO_PASSWORD=physio123

# Service key (server-only) — enables fixtures that seed deterministic
# preconditions (appointments/packages) for reschedule/cancel/complete specs.
# NEVER commit a real key; export it at runtime only.
MANGGALEH_SERVICE_KEY=mgsk_your_service_key

# --- opt-ins / environment ---
# Allow the registration spec to create a real permanent account.
E2E_ALLOW_SIGNUP=false
# Pre-provisioned Chromium so the pinned Playwright doesn't download a browser.
# (In this managed environment: /opt/pw-browsers/chromium)
PW_CHROMIUM_PATH=/opt/pw-browsers/chromium
# Dev server port for the built preview.
E2E_PORT=4173
